{
  "manifest_version": 3,
  "name": "weixin-clip",
  "version": "0.1.2",
  "description": "Clip WeChat public account articles to Markdown + images (Obsidian / local folder).",
  "icons": {
    "48": "icons/icon48.png"
  },
  "permissions": ["contextMenus", "storage", "notifications", "scripting"],
  "host_permissions": ["https://mp.weixin.qq.com/*", "https://*/*"],
  "background": {
    "service_worker": "sw.js"
  },
  "options_page": "options.html"
}
